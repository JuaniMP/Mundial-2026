# ============================================================
# Mundial-2026 — root gitignore
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# Build outputs
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
.vite/
*.tsbuildinfo

# Coverage & test outputs
coverage/
*.lcov
.nyc_output/
playwright-report/
test-results/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editors / IDEs
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.shared.json
*.swp
*.swo
.DS_Store
Thumbs.db

# Env files (never commit secrets)
.env
.env.local
.env.*.local
!.env.example

# OS
*.tmp
*.temp
*~

# Java / Spring Boot (apps/api)
target/
*.jar
*.war
*.class
hs_err_pid*
.mvn/
mvnw
mvnw.cmd

# OpenCode tooling artifacts (no van al repo)
.opencode/

# Original assets archived (mantener uncompressed in design-source/)
*.zip

# Dumps & local databases
*.sqlite
*.db
dump.sql
