# Copia este archivo como .env.local y rellena tus valores

# ── Stripe Sandbox ────────────────────────────────────────────────────────────
VITE_STRIPE_PK=pk_test_REEMPLAZA_CON_TU_PUBLISHABLE_KEY

# ── Firebase FCM (Push Notifications) ────────────────────────────────────────
# Obtén estos valores en: Firebase Console → Tu proyecto → Configuración → General → Tus apps
VITE_FIREBASE_API_KEY=REEMPLAZA_CON_TU_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=REEMPLAZA_CON_TU_SENDER_ID
VITE_FIREBASE_APP_ID=1:REEMPLAZA:web:REEMPLAZA
# VAPID Key: Firebase Console → Cloud Messaging → Configuración web → Certificados push web
VITE_FIREBASE_VAPID_KEY=REEMPLAZA_CON_TU_VAPID_KEY
