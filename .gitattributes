# Normalize line endings
* text=auto eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Linguist overrides — design-source mockups no cuentan como código del proyecto
docs/design-source/** linguist-vendored
docs/design-source/**/*.html linguist-vendored
