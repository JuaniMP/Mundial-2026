# ─────────────────────────────────────────────────────────────────────────────
#  backend/.env.local.example
#  Copia este archivo como backend/.env.local y rellena los valores reales.
#  .env.local está en .gitignore — NUNCA lo subas al repositorio.
# ─────────────────────────────────────────────────────────────────────────────

# ── Base de datos (VM remota via Tailscale) ───────────────────────────────────
DB_USER=juanita_mh
DB_PASSWORD=TU_PASSWORD_MYSQL_AQUI

# ── JWT (generar con: openssl rand -base64 64) ────────────────────────────────
JWT_SECRET=TU_JWT_SECRET_BASE64_AQUI_MINIMO_256_BITS
JWT_EXPIRATION_MS=3600000

# ── Stripe (Sandbox) — Dashboard: https://dashboard.stripe.com/apikeys ────────
STRIPE_SECRET_KEY=sk_test_TU_CLAVE_SECRETA
STRIPE_PUBLISHABLE_KEY=pk_test_TU_CLAVE_PUBLICA
STRIPE_WEBHOOK_SECRET=whsec_TU_WEBHOOK_SECRET

# ── Firebase FCM (Push Notifications) ────────────────────────────────────────
FIREBASE_ENABLED=true
# Opcion A: ruta al archivo JSON de la service account
FIREBASE_SERVICE_ACCOUNT_FILE=C:\ruta\al\archivo\service-account.json
# Opcion B: JSON inline (alternativa, descomentar si no usas archivo)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── Email (Gmail SMTP) — App Password: myaccount.google.com/apppasswords ──────
MAIL_USERNAME=mundialparatodos2026@gmail.com
MAIL_PASSWORD=TU_APP_PASSWORD_GMAIL

# ── Football Data API — football-data.org ─────────────────────────────────────
FOOTBALL_DATA_KEY=TU_API_KEY_AQUI

# ── CORS (produccion: pon tu dominio real) ────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_RPM=60
RATE_LIMIT_BURST=20
